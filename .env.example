# ─── WhatsApp Cloud API ──────────────────────────────────────────────────────
# From Meta Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here

# The token you set when registering the webhook in Meta Business Manager
VERIFY_TOKEN=myverifytoken123

# ─── DeepSeek API ────────────────────────────────────────────────────────────
# Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Model to use (deepseek-chat = DeepSeek-V3, or swap for newer model)
DEEPSEEK_MODEL=deepseek-chat

# ─── Escalation ──────────────────────────────────────────────────────────────
# Your personal WhatsApp number — country code + number, NO '+' sign
# Example for India: 919876543210
OWNER_PHONE_NUMBER=91XXXXXXXXXX

# ─── Storage ─────────────────────────────────────────────────────────────────
# /tmp persists within a Render session (resets on restart)
# For full persistence, point to a mounted disk path e.g. /var/data/re_agent.db
DB_PATH=/tmp/re_agent.db
